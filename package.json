{
    "name": "pentagon-launcher",
    "version": "0.2.0",
    "description": "Pentagon — A Modern Minecraft Launcher",
    "main": "dist-electron/main.js",
    "author": "Pentagon Team",
    "license": "MIT",
    "scripts": {
        "dev": "vite",
        "build": "cross-env CSC_LINK=null vite build && electron-builder",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@types/adm-zip": "^0.5.7",
        "adm-zip": "^0.5.16",
        "lucide-react": "^0.500.0",
        "prismarine-nbt": "^2.8.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.4.0",
        "cross-env": "^10.1.0",
        "electron": "^33.0.0",
        "electron-builder": "^26.0.0",
        "typescript": "^5.8.0",
        "vite": "^6.2.0",
        "vite-plugin-electron": "^0.28.0",
        "vite-plugin-electron-renderer": "^0.14.0"
    },
    "build": {
        "appId": "com.pentagon.launcher",
        "productName": "Pentagon Launcher",
        "directories": {
            "output": "release/${version}"
        },
        "files": [
            "dist-electron",
            "dist",
            "package.json"
        ],
        "win": {
            "forceCodeSigning": false,
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "dir",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        }
    }
}
